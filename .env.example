# --- Database ---------------------------------------------------------------
# Local dev points at the compose postgres (host port 5434; 5433 is often taken by other local stacks).
DATABASE_URL=postgresql://haven:haven_dev@localhost:5434/havenhub
# Direct (unpooled) connection used by `prisma migrate` only -- its advisory lock
# needs a stable session, which a PgBouncer pooler (e.g. Neon's -pooler endpoint)
# cannot guarantee. On Neon, this is the connection string WITHOUT "-pooler" in the
# host (Neon's Vercel integration provisions it as DATABASE_URL_UNPOOLED). Locally
# with a non-pooled Postgres, set it to the same value as DATABASE_URL.
DATABASE_URL_UNPOOLED=postgresql://haven:haven_dev@localhost:5434/havenhub
# Used by `npm test` (vitest.setup.ts). Created by `npm run test:prepare`.
TEST_DATABASE_URL=postgresql://haven:haven_dev@localhost:5434/havenhub_test

# --- Auth -------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me
# Microsoft Entra ID app registration (Yale tenant).
# OPTIONAL in development (dev credentials login works without them),
# REQUIRED in production. Boot fails loudly if missing.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# --- Airtable ----------------------------------------------------------------
# Personal access token. Needed for the importer (reads) and the mirror (writes).
# Scopes: data.records:read on HAVEN Management; data.records:write + schema.bases:read
# on the mirror target base.
AIRTABLE_PAT=
# Read sources (defaults are the real HAVEN Management base; IDs are not secrets).
HAVEN_MGMT_BASE_ID=appkxTQ19GmaHgW1O
ALL_PEOPLE_TABLE_ID=tblnHgBpknuqWvx9c
SU26_ROSTER_TABLE_ID=tbl2VrP1uqwFt7QNQ
# Mirror (WRITES). Keep disabled until the FA26 cutover. While developing,
# point these at the sandbox base, never at HAVEN Management.
AIRTABLE_MIRROR_ENABLED=false
AIRTABLE_MIRROR_BASE_ID=
AIRTABLE_MIRROR_PEOPLE_TABLE_ID=
# Optional JSON field-ID map. Required for the sandbox base because sandbox field IDs
# differ from the production defaults in ALL_PEOPLE_FIELDS. Omit for production target.
# Example (sandbox base app39808T8G8XbJig / table tblGjuOFx9ACMzps1):
# AIRTABLE_MIRROR_FIELD_MAP={"name":"fldnyPNurTfUTCI3M","netId":"fldzDXBuegWh43qBe","contactEmail":"flddaZKIRSx3xoss3","phone":"fldKV9uyerHHBr9VB","epicId":"fldYAk27EVKbK9GZn","yaleAffiliation":"fldcqbmdOvL1ZwXgH","gradYear":"fldVjHtbPzhGXeH75"}
AIRTABLE_MIRROR_FIELD_MAP=
# HIPAA certificate attachment push. The field ID of the attachment field on the mirrored
# people table. OPTIONAL even when the mirror is enabled -- if unset, the certificate
# attachment push is skipped (with a log notice) rather than failing. Set this once you
# have an attachment field in your Airtable base.
AIRTABLE_MIRROR_HIPAA_FIELD_ID=
# HIPAA compliance status mirror. The field ID of the "HIPAA Compliance Status" singleSelect
# on the mirrored people table. The computed status collapses to "Compliant" (only when
# COMPLIANT) or "Not Compliant" (everything else) and is written by name (typecast:true).
# OPTIONAL even when the mirror is enabled -- if unset, the status is not written.
# Production value (HAVEN Management All People): fldaDo5T6mhX9IHhb
# The sandbox base has NO such field, so leave this unset for sandbox; the live status-mirror
# smoke is deferred to the cutover runbook (it needs the production field or a sandbox field
# created for it).
AIRTABLE_MIRROR_STATUS_FIELD_ID=

# --- Uploads -----------------------------------------------------------------
# Directory where uploaded HIPAA certificates are stored on disk.
# In production (SpinUp) this should be a mounted persistent volume.
UPLOAD_DIR=./uploads
# Maximum allowed upload size in megabytes (must be a positive integer).
# Defaults to 5 -- Airtable's content upload API caps attachments at 5 MB.
MAX_UPLOAD_MB=5

# Email transport. "log" (default) prints to stdout; "graph" sends via Microsoft
# Graph using the delegated OAuth flow (an admin connects a mailbox in Admin > Email).
EMAIL_TRANSPORT=log
# The mailbox to send AS (a shared mailbox the connecting admin can send from).
EMAIL_SENDER=hfc.it@yale.edu
# "HAVEN Hub Mailer" Entra app registration (delegated Mail.Send + Mail.Send.Shared
# + offline_access + Channel.ReadBasic.All). Channel.ReadBasic.All (used for the
# clinic Teams channel link) requires tenant admin consent; the Mail scopes do not.
# Required when EMAIL_TRANSPORT=graph.
GRAPH_OAUTH_TENANT_ID=
GRAPH_OAUTH_CLIENT_ID=
GRAPH_OAUTH_CLIENT_SECRET=
GRAPH_OAUTH_REDIRECT_URI=http://localhost:3000/admin/email/oauth/callback
# Microsoft Teams clinic Team groupId (the Team that holds one channel per clinic
# week, each named "MM-DD-YY Clinic"). When set, the home dashboard links to the
# current week's channel. Requires the Mailer OAuth to be re-consented with the
# Channel.ReadBasic.All scope, and the connected mailbox to be a member of the Team.
TEAMS_CLINIC_GROUP_ID=
# Teams direct-message notifications reuse the Graph OAuth credentials above and
# the connected mailbox. After deploying, an admin must RECONNECT the mailbox in
# /admin/email once to grant the added Chat.Create + ChatMessage.Send scopes.
# Per-type routing (Email / Teams / Both) is configured in /admin/settings.
