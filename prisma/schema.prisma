generator client {
  provider = "prisma-client-js"
  // "native" covers local dev + CI (Debian). "rhel-openssl-3.0.x" is the Vercel
  // Lambda runtime: required because preview deployments are built in GitHub
  // Actions (Debian) and shipped with `vercel deploy --prebuilt`, so the query
  // engine is bundled at build time rather than generated on Vercel's RHEL infra.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // App runtime uses the pooled connection (PgBouncer). Migrations use a DIRECT
  // (unpooled) connection: Prisma's migration advisory lock is session-scoped and
  // times out over the pooler. DATABASE_URL_UNPOOLED is provisioned by Neon's
  // Vercel integration; locally it can equal DATABASE_URL (no pooler in dev/CI).
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum PersonStatus {
  ACTIVE
  OFFBOARDED
}

enum ShiftRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum ShiftRole {
  DIRECTOR
  VOLUNTEER
  SHADOW
}

enum TermStatus {
  PLANNING
  ACTIVE
  ARCHIVED
}

enum MembershipKind {
  DIRECTOR
  VOLUNTEER
}

enum MembershipStatus {
  ACTIVE
  REMOVED
}

enum CertificateSource {
  UPLOAD
  IMPORT
}

enum CertificateExtraction {
  PARSED
  MANUAL
  AIRTABLE
  NONE
}

model Person {
  id                        String               @id @default(cuid())
  netId                     String?              @unique
  entraObjectId             String?              @unique
  name                      String
  contactEmail              String?              @unique
  phone                     String?
  epicId                    String?
  yaleAffiliation           String?
  /// UI appearance preference: null = use the app default (ui.defaultTheme).
  /// One of "light" | "dark" | "system". Stored as a string (not an enum) to
  /// match the settings registry's string select and avoid a Prisma enum migration.
  themePreference           String?
  gradYear                  String?
  status                    PersonStatus         @default(ACTIVE)
  airtableRecordId          String?              @unique
  /// The HIPAA compliance status the Airtable mirror last asserted ("Compliant" /
  /// "Not Compliant"). Mirror bookkeeping only: set by drainPersonRow after a
  /// successful send so the nightly refresh can detect changes without re-reading Airtable.
  mirroredHipaaStatus       String?
  memberships               TermMembership[]
  roleAssignments           RoleAssignment[]
  hipaaCertificates         HipaaCertificate[]
  /// Offboard flags where this person is the subject.
  offboardFlags             OffboardFlag[]       @relation("offboardFlagPerson")
  /// Offboard flags this person issued (as the flagger).
  offboardFlagsIssued       OffboardFlag[]       @relation("offboardFlagFlaggedBy")
  /// EPIC access requests where this person is the subject.
  epicRequests              EpicRequest[]        @relation("epicRequestPerson")
  /// EPIC access requests this person submitted on behalf of another.
  epicRequestsSubmitted     EpicRequest[]        @relation("epicRequestRequestedBy")
  /// YNHH tickets this person submitted.
  ynhhTicketsSubmitted      YnhhTicket[]         @relation("ynhhTicketSubmittedBy")
  /// Disciplinary actions recorded against this person.
  disciplinaryActions       DisciplinaryAction[] @relation("disciplinaryActionPerson")
  /// Disciplinary actions this person issued.
  disciplinaryActionsIssued DisciplinaryAction[] @relation("disciplinaryActionIssuedBy")
  /// Email log rows addressed to or triggered by this person.
  emailLogs                 EmailLog[]           @relation("emailLogPerson")
  /// Email log rows this person triggered (may differ from the recipient).
  emailLogsTriggered        EmailLog[]           @relation("emailLogTriggeredBy")
  emailTemplatesUpdated                 EmailTemplate[]         @relation("emailTemplateUpdatedBy")
  recruitmentCycleEmailsUpdated         RecruitmentCycleEmail[] @relation("recruitmentCycleEmailUpdatedBy")
  campaignsCreated          EmailCampaign[]      @relation("campaignCreatedBy")
  complianceReminder        ComplianceReminder?
  teamsMessages             TeamsMessage[]       @relation("teamsMessagePerson")
  notifications             Notification[]       @relation("personNotifications")
  shiftAssignments          ShiftAssignment[]
  recruitmentCyclesCreated  RecruitmentCycle[]   @relation("RecruitmentCycleCreatedBy")
  recruitmentAcceptances    Acceptance[]         @relation("recruitmentAcceptanceApprover")
  applicantSubmissions      Applicant[]          @relation("ApplicantPerson")
  contractsPromoted         OnboardingContract[] @relation("contractPromotedBy")
  contractsPromotedTo       OnboardingContract[] @relation("contractPromotedPerson")
  interviewsCreated         Interview[]          @relation("interviewCreatedBy")
  interviewsDecided         Interview[]          @relation("interviewDecidedBy")
  interviewPanels           InterviewPanelist[]  @relation("interviewPanelistPerson")
  interviewEvaluations      Evaluation[]         @relation("interviewEvaluator")
  trainings                Training[]  @relation("trainingPerson")
  trainingAttendanceMarked Training[]  @relation("trainingAttendanceRecorder")
  subcommitteeAssignments  Application[] @relation("applicationSubcommitteeAssigner")
  courseProgress            CourseProgress[]
  scoProgress               ScoProgress[]
  /// Shift requests this person raised.
  shiftRequests             ShiftRequest[]       @relation("shiftRequestRequester")
  /// Shift requests targeting this person as the swap partner.
  shiftRequestsTargeted     ShiftRequest[]       @relation("shiftRequestTarget")
  /// Shift requests this person decided (approved or denied).
  shiftRequestsDecided      ShiftRequest[]       @relation("shiftRequestDecidedBy")
  /// Self-reported at onboarding (or set by an admin). Intake signal only; does NOT gate scheduling.
  spanishSelfReported       Boolean              @default(false)
  /// Interpreting-department-confirmed Spanish capability. Gates clinical scheduling.
  spanishVerified           Boolean              @default(false)
  /// When the interpreting department (or an admin override) recorded the verification. Null = never assessed.
  spanishVerifiedAt         DateTime?
  /// Verifier's Person id. Bare id (no FK), mirroring HipaaCertificate.verifiedById.
  spanishVerifiedById       String?
  /// Self-reported RN licensure. No verification workflow.
  licensedRN                Boolean              @default(false)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
}

/// Uploaded HIPAA training certificates. One row per upload.
/// File bytes live on disk under UPLOAD_DIR/<storedName>; this row is the
/// source of truth for ownership and metadata. Cascade-deleted with the person.
model HipaaCertificate {
  id             String                @id @default(cuid())
  personId       String
  /// Original filename as supplied by the uploader (display only; never used in file I/O).
  fileName       String
  /// Server-generated filename stored under UPLOAD_DIR (e.g. "<cuid>.pdf"). Used for disk I/O.
  storedName     String
  size           Int
  mimeType       String
  source         CertificateSource     @default(UPLOAD)
  completionDate DateTime?
  extraction     CertificateExtraction @default(NONE)
  verifiedById   String?
  verifiedAt     DateTime?
  uploadedAt     DateTime              @default(now())
  person         Person                @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId, uploadedAt])
}

model Term {
  id                 String              @id @default(cuid())
  code               String              @unique // "SU26", "FA26"
  name               String // "Summer 2026"
  startDate          DateTime
  endDate            DateTime
  status             TermStatus          @default(PLANNING)
  clinicDates        DateTime[]
  memberships        TermMembership[]
  roleAssignments    RoleAssignment[]
  /// Offboard flags raised for this term.
  offboardFlags      OffboardFlag[]
  shiftAssignments   ShiftAssignment[]
  shiftRequests      ShiftRequest[]
  scheduleDays       ScheduleDay[]
  rhdClinics         RhdClinic[]
  recruitmentCycles  RecruitmentCycle[]
  trainings Training[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Department {
  id                         String                 @id @default(cuid())
  code                       String                 @unique // "ITCM", "EXEC", "SRR", ...
  name                       String
  isActive                   Boolean                @default(true)
  memberships                TermMembership[]
  roleAssignments            RoleAssignment[]
  /// Delegations where this department is the MANAGER (it manages the listed departments).
  managesDelegations         DepartmentDelegation[] @relation("delegationManager")
  /// Delegations where this department is MANAGED BY another department.
  managedByDelegations       DepartmentDelegation[] @relation("delegationManaged")
  shiftAssignments           ShiftAssignment[]
  shiftRequests              ShiftRequest[]
  scheduleDays               ScheduleDay[]
  courseDepartments          CourseDepartment[]
  /// Capacity panel config: imported then admin-maintained.
  idealHeadcount             Int?
  /// Capacity panel config: imported then admin-maintained.
  patientCapacityPerProvider Int?
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
}

/// Admin-managed subcommittees applicants rank at application time and the
/// recruitment team assigns post-acceptance. Soft-delete via isActive so
/// historical rankings always resolve to a name.
model Subcommittee {
  id                   String        @id @default(cuid())
  name                 String
  isActive             Boolean       @default(true)
  order                Int           @default(0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  assignedApplications Application[] @relation("applicationAssignedSubcommittee")

  @@index([isActive, order])
}

/// One row per "manager department oversees managed department" edge. Used to
/// extend a director's compliance scope beyond their own department(s) by one
/// hop (no recursion). Example: PCAR manages SCTP and JCTP.
model DepartmentDelegation {
  id                  String     @id @default(cuid())
  managerDepartmentId String
  managedDepartmentId String
  manager             Department @relation("delegationManager", fields: [managerDepartmentId], references: [id], onDelete: Cascade)
  managed             Department @relation("delegationManaged", fields: [managedDepartmentId], references: [id], onDelete: Cascade)

  @@unique([managerDepartmentId, managedDepartmentId])
}

model TermMembership {
  id                         String           @id @default(cuid())
  personId                   String
  termId                     String
  departmentId               String
  kind                       MembershipKind
  status                     MembershipStatus @default(ACTIVE)
  /// Tier 3 (lowest): availability from the member's application, set at import
  /// or roster build. The fallback when no self update or director override exists.
  baselineAvailability       DateTime[]
  /// Free-text availability from volunteer self-update (legacy scheduler behavior).
  /// Read-only note since plan 7; superseded by selfAvailabilityDates.
  selfUpdatedAvailability    String?
  /// Set whenever the member self-updates availability (free text historically,
  /// structured dates since plan 7); doubles as the presence marker for tier 2.
  availabilityUpdatedAt      DateTime?
  availabilityAcknowledgedAt DateTime?
  /// Tier 2: structured self-updated availability (clinic dates the member can
  /// attend). Presence is signaled by availabilityUpdatedAt; replaces the
  /// legacy free-text selfUpdatedAvailability, which stays read-only as a note.
  selfAvailabilityDates      DateTime[]
  /// Tier 1 (highest): director override. Empty-but-set is distinguished from
  /// never-set by directorAvailabilitySetAt.
  directorAvailabilityDates  DateTime[]
  directorAvailabilitySetAt  DateTime?
  person                     Person           @relation(fields: [personId], references: [id])
  term                       Term             @relation(fields: [termId], references: [id])
  department                 Department       @relation(fields: [departmentId], references: [id])
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  @@unique([personId, termId, departmentId, kind])
  @@index([termId, departmentId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  grants      RoleGrant[]
  assignments RoleAssignment[]
}

model RoleGrant {
  id         String @id @default(cuid())
  roleId     String
  permission String // e.g. "schedule.edit_all" or "*"
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
}

/// Exactly one of personId / departmentId is set. termId null = global scope.
/// DB-LEVEL GUARDS LIVE IN RAW SQL (see migrations): a COALESCE unique index
/// (duplicate grants) and a CHECK constraint (target XOR). Guarded by
/// src/platform/rbac/schema-guards.test.ts. Never resolve a prisma migrate
/// diff by accepting a DROP of objects you do not recognize.
model RoleAssignment {
  id           String      @id @default(cuid())
  roleId       String
  personId     String?
  departmentId String?
  termId       String?
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  person       Person?     @relation(fields: [personId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  term         Term?       @relation(fields: [termId], references: [id], onDelete: Restrict)

  @@index([personId])
  @@index([departmentId])
  @@index([termId])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorPersonId String?
  action        String // e.g. "person.update", "auth.login_unmatched"
  entityType    String
  entityId      String?
  before        Json?
  after         Json?
  ip            String?
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorPersonId])
}

enum OutboxStatus {
  PENDING
  SENT
  FAILED
}

enum EpicRequestKind {
  NEW
  MODIFY
  RENEW
}

enum EpicRequestStatus {
  PENDING
  SUBMITTED
  COMPLETED
  CANCELLED
}

enum YnhhTicketStatus {
  OPEN
  CLOSED
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
}

enum TeamsMessageStatus {
  QUEUED
  SENT
  FAILED
  /// Teams delivery was abandoned and the message was re-queued as email instead.
  FALLBACK
  /// The log transport ran (email.transport is not "graph"): the message was
  /// recorded but NOT actually sent. Distinct from SENT so the monitor never
  /// implies real delivery in log mode. Retryable once graph is enabled.
  LOGGED
}

enum RecruitmentTrack {
  VOLUNTEER
  DIRECTOR
}

enum CycleStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

enum FieldType {
  SHORT_TEXT
  LONG_TEXT
  SINGLE_SELECT
  MULTI_SELECT
  CHECKBOX
  EMAIL
  PHONE
  NUMBER
  DATE
  FILE
  DEPARTMENT_CHOICE
  SUBCOMMITTEE_RANK
}

enum ApplicantScope {
  NEW
  RENEWAL
  BOTH
}

enum ApplicantType {
  NEW
  RENEWAL
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
}

enum InterviewDecision {
  PENDING
  ACCEPT
  REJECT
  WAITLIST
}

enum Recommendation {
  STRONG_YES
  YES
  MAYBE
  NO
}

enum ContractStatus {
  PENDING
  SUBMITTED
  PROMOTED
}

enum FormPurpose {
  APPLICATION
  QUIZ
}

enum TrainingStatus {
  PENDING
  COMPLETE
}

enum TrainingMethod {
  ATTENDANCE
  QUIZ
}

enum TrainingTrack {
  VOLUNTEER
  DIRECTOR
}

/// One row per mirrored change. Written in the same transaction as the domain
/// write; drained by the worker. FAILED rows persist for inspection and are
/// also self-healed by nightly reconciliation.
model Outbox {
  id            String       @id @default(cuid())
  entityType    String // "Person"
  entityId      String
  operation     String // "upsert"
  changedFields String[]
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  lastError     String?
  createdAt     DateTime     @default(now())
  processedAt   DateTime?

  @@index([status, createdAt])
}

/// Maps a Postgres entity to its Airtable record id in a specific base.
/// Needed because the sandbox and production bases have different record ids.
model MirrorRecord {
  id         String @id @default(cuid())
  entityType String
  entityId   String
  baseId     String
  recordId   String

  @@unique([entityType, entityId, baseId])
}

model WorkerHeartbeat {
  id     String   @id // e.g. "mirror-worker"
  beatAt DateTime
}

/// Flags a person for offboarding at the end of a given term. At most one flag
/// per (person, term) pair. Cascade-deleted when the person or term is removed
/// (flags are transient workflow state with no independent archival value).
model OffboardFlag {
  id          String   @id @default(cuid())
  personId    String
  termId      String
  flaggedById String
  note        String?
  createdAt   DateTime @default(now())
  /// Subject of the flag. Cascade: if the person is deleted the flag is meaningless.
  person      Person   @relation("offboardFlagPerson", fields: [personId], references: [id], onDelete: Cascade)
  /// Term in which the person should be offboarded. Cascade: if the term is deleted the flag is meaningless.
  term        Term     @relation(fields: [termId], references: [id], onDelete: Cascade)
  /// Person who raised the flag. Restrict: flags are workflow state the offboarding executor acts on; deleting a person who flagged others must not silently empty the queue.
  flaggedBy   Person   @relation("offboardFlagFlaggedBy", fields: [flaggedById], references: [id], onDelete: Restrict)

  @@unique([personId, termId])
}

/// A request to create, modify, or renew a person's EPIC EMR access. Linked
/// optionally to a YnhhTicket once one is opened with YNHH IT. Cascade-deleted
/// with the person (the person is the subject of the request).
model EpicRequest {
  id            String            @id @default(cuid())
  personId      String
  kind          EpicRequestKind
  status        EpicRequestStatus @default(PENDING)
  jobTitle      String?
  mirrorEpicId  String?
  notes         String?
  requestedById String
  ticketId      String?
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  /// Subject of the request. Cascade: requests belong to the person.
  person        Person            @relation("epicRequestPerson", fields: [personId], references: [id], onDelete: Cascade)
  /// Person who submitted the request. Restrict: any referencing row blocks deletion of this person.
  requestedBy   Person            @relation("epicRequestRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  /// The YNHH ticket opened for this request (optional).
  ticket        YnhhTicket?       @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([personId, status])
}

/// A service request ticket opened with YNHH IT, grouping one or more EPIC
/// access requests. Rows are kept for audit purposes even after the ticket closes.
model YnhhTicket {
  id                   String           @id @default(cuid())
  serviceRequestNumber String?
  description          String?
  status               YnhhTicketStatus @default(OPEN)
  submittedById        String
  submittedAt          DateTime         @default(now())
  closedAt             DateTime?
  /// EPIC requests grouped under this ticket.
  requests             EpicRequest[]
  /// Person who submitted the ticket to YNHH IT. Restrict: any referencing row blocks deletion of this person.
  submittedBy          Person           @relation("ynhhTicketSubmittedBy", fields: [submittedById], references: [id], onDelete: Restrict)
}

/// A formal disciplinary action recorded against a volunteer or director.
/// Cascade-deleted with the person (the subject); issuer uses Restrict so a
/// director cannot be deleted while they have issued actions.
model DisciplinaryAction {
  id              String   @id @default(cuid())
  personId        String
  issuedById      String
  occurredAt      DateTime
  category        String
  description     String
  followUpActions String?
  policyReference String?
  notes           String?
  confidential    Boolean  @default(false)
  patientInvolved Boolean  @default(false)
  createdAt       DateTime @default(now())
  /// Subject of the action. Cascade: records belong to the person.
  person          Person   @relation("disciplinaryActionPerson", fields: [personId], references: [id], onDelete: Cascade)
  /// Person who issued the action. Restrict: the issuer should not be deleted while records exist.
  issuedBy        Person   @relation("disciplinaryActionIssuedBy", fields: [issuedById], references: [id], onDelete: Restrict)

  @@index([personId])
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  SENDING
  SENT
  CANCELLED
}

model EmailCampaign {
  id           String              @id @default(cuid())
  name         String
  recordType   String              @default("PERSON")
  audienceJson Json
  subject      String              @default("")
  body         String              @default("")
  status       EmailCampaignStatus @default(DRAFT)
  scheduleType String              @default("NOW") // NOW | SCHEDULED | RECURRING
  scheduledAt  DateTime?
  cronExpr     String?
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  createdById  String?
  createdBy    Person?             @relation("campaignCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  runs         EmailCampaignRun[]
}

model EmailCampaignRun {
  id             String        @id @default(cuid())
  campaignId     String
  campaign       EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  runAt          DateTime      @default(now())
  recipientCount Int           @default(0)
  status         String        @default("SENT")
  emails         EmailLog[]    @relation("emailLogCampaignRun")

  @@index([campaignId])
}

/// Outbox for transactional emails. The drain worker reads QUEUED rows and
/// sends them via the mail provider. Unlike Outbox, the html body is stored
/// on the row so the drain needs no template knowledge. Both person references
/// are optional with SetNull so email history survives person deletion.
model EmailLog {
  id            String            @id @default(cuid())
  toEmail       String
  subject       String
  html          String
  template      String
  /// Person the email was addressed to (optional; may be null for non-person recipients).
  personId      String?
  /// Person who triggered the email (e.g. the director who performed an action). SetNull on delete.
  triggeredById String?
  campaignRunId String?
  status        EmailStatus       @default(QUEUED)
  attempts      Int               @default(0)
  lastError     String?
  sentAt        DateTime?
  createdAt     DateTime          @default(now())
  /// SetNull: email logs outlive the people they reference.
  person        Person?           @relation("emailLogPerson", fields: [personId], references: [id], onDelete: SetNull)
  /// SetNull: email logs outlive the people they reference.
  triggeredBy   Person?           @relation("emailLogTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)
  campaignRun   EmailCampaignRun? @relation("emailLogCampaignRun", fields: [campaignRunId], references: [id], onDelete: SetNull)

  @@unique([campaignRunId, toEmail])
  @@index([personId])
  @@index([status, createdAt])
}

/// Admin override of a code-default email template, keyed by descriptor key (e.g. "layout", "compliance-reminder").
model EmailTemplate {
  id          String   @id @default(cuid())
  /// Descriptor key this row overrides. Unique: at most one override per template.
  key         String   @unique
  subject     String
  body        String
  updatedById String?
  updatedBy   Person?  @relation("emailTemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Per-cycle override of a recruitment email. A row exists only when a cycle
/// customizes that email; absence means inherit the global default. `key` is one
/// of the cycle-scoped recruitment descriptor keys (not recruitment.portal_link).
model RecruitmentCycleEmail {
  id          String           @id @default(cuid())
  cycleId     String
  cycle       RecruitmentCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  key         String
  subject     String
  body        String
  updatedById String?
  updatedBy   Person?          @relation("recruitmentCycleEmailUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([cycleId, key])
}

/// Per-person HIPAA reminder state. Drives the weekly cadence (lastRemindedAt),
/// the escalation threshold (remindersSent), and the once-only director
/// escalation (escalatedAt). Reset to zero when the person becomes COMPLIANT.
model ComplianceReminder {
  id             String    @id @default(cuid())
  personId       String    @unique
  remindersSent  Int       @default(0)
  lastRemindedAt DateTime?
  lastStatus     String?
  escalatedAt    DateTime?
  person         Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
}

/// Single-row store for the delegated Graph mail credential (the rotating
/// refresh token and connection metadata). id defaults to a fixed sentinel so
/// there is at most one row.
model MailCredential {
  id           String   @id @default("mailer")
  refreshToken String
  account      String?
  scope        String?
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Outbound Teams 1:1 chat message queue (mirrors EmailLog). Drained by the
/// email cron alongside the email queue. Carries the email fallback payload so a
/// permanently-failed Teams send degrades to email without re-involving the caller.
model TeamsMessage {
  id              String             @id @default(cuid())
  /// Recipient person. Teams messages are always person-addressed.
  personId        String
  /// Notification type key from the notification registry (e.g. "compliance-reminder").
  type            String
  title           String
  summary         String
  link            String?
  /// Rendered HTML body posted to the Teams chat.
  bodyHtml        String
  /// Cached 1:1 chat id once resolved, so a retry does not re-create the chat.
  chatId          String?
  /// Email fallback payload, queued if Teams delivery fails permanently.
  fallbackSubject String
  fallbackHtml    String
  status          TeamsMessageStatus @default(QUEUED)
  attempts        Int                @default(0)
  lastError       String?
  sentAt          DateTime?
  createdAt       DateTime           @default(now())
  /// Cascade: Teams messages do not outlive the person they address.
  person          Person             @relation("teamsMessagePerson", fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([status, createdAt])
}

/// Per-person in-app notification (the bell inbox). Written unconditionally by
/// notify() for every notification addressed to a person, independent of the
/// Email/Teams channel routing. readAt null means unread.
model Notification {
  id        String    @id @default(cuid())
  personId  String
  /// Notification registry key (e.g. "epic-activation").
  type      String
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  /// Cascade: notifications do not outlive the person they address.
  person    Person    @relation("personNotifications", fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId, createdAt])
  @@index([personId, readAt])
}

/// One row per person per clinic shift. Med-team tags apply to VOLUNTEER rows;
/// the legacy invariant holds: a triage/walk-in/CC/remote designee is also on
/// shift (their row IS the on-shift row, tags are attributes of it).
model ShiftAssignment {
  id           String     @id @default(cuid())
  termId       String
  departmentId String
  personId     String
  /// Calendar date, anchored at 12:00 UTC like Term.clinicDates and the
  /// availability arrays. Compare by UTC day key, never by raw timestamp.
  clinicDate   DateTime
  role         ShiftRole
  triage       Boolean    @default(false)
  walkin       Boolean    @default(false)
  cc           Boolean    @default(false)
  remote       Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  /// Restrict: term deletion is blocked while schedule history references it.
  term         Term       @relation(fields: [termId], references: [id], onDelete: Restrict)
  /// Restrict: department deletion is blocked while schedule history references it.
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  /// Cascade: assignments belong to the person and die with them.
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([termId, departmentId, clinicDate, personId])
  @@index([termId, clinicDate])
  @@index([personId, termId])
}

/// Swap/drop requests against the schedule. Drop when targetId/targetDate are
/// null; named swap otherwise. Approval re-validates and applies transactionally.
/// DB-LEVEL GUARDS LIVE IN RAW SQL (see migrations): a partial unique index
/// (ShiftRequest_pending_unique) prevents duplicate PENDING rows for the same
/// (requesterId, requesterDate, departmentId) triple. Guarded by
/// src/modules/schedule/services/schedule-schema-guards.test.ts. Never resolve
/// a prisma migrate diff by accepting a DROP of objects you do not recognize.
model ShiftRequest {
  id            String             @id @default(cuid())
  termId        String
  requesterId   String
  /// Clinic date of the shift being dropped or swapped away (noon-UTC anchored).
  requesterDate DateTime
  departmentId  String
  targetId      String?
  /// Populated only for swaps; may remain set even if targetId was NULLed by
  /// onDelete SetNull. The service layer must treat (targetId null AND
  /// targetDate set) as a stale/malformed swap.
  targetDate    DateTime?
  status        ShiftRequestStatus @default(PENDING)
  note          String?
  decidedById   String?
  decidedAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  term          Term               @relation(fields: [termId], references: [id], onDelete: Restrict)
  requester     Person             @relation("shiftRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target        Person?            @relation("shiftRequestTarget", fields: [targetId], references: [id], onDelete: SetNull)
  decidedBy     Person?            @relation("shiftRequestDecidedBy", fields: [decidedById], references: [id], onDelete: Restrict)
  department    Department         @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@index([termId, departmentId, status])
  @@index([requesterId])
}

/// Per-(department, clinic date) operational data maintained by directors
/// in the builder (currently: patients booked, for capacity math).
model ScheduleDay {
  id             String     @id @default(cuid())
  termId         String
  departmentId   String
  /// Noon-UTC anchored calendar date; compare by UTC day key.
  clinicDate     DateTime
  patientsBooked Int?
  term           Term       @relation(fields: [termId], references: [id], onDelete: Restrict)
  department     Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@unique([termId, departmentId, clinicDate])
}

/// RHD attending physicians and their procedure qualification matrix.
/// Procedure values are "yes" | "no" | "unknown" strings (legacy semantics).
model RhdAttending {
  id           String      @id @default(cuid())
  scheduleName String      @unique
  fullName     String
  iudIn        String      @default("unknown")
  iudOut       String      @default("unknown")
  nexplanon    String      @default("unknown")
  gac          String      @default("unknown")
  emb          String      @default("unknown")
  seesMale     String      @default("unknown")
  notes        String?
  isActive     Boolean     @default(true)
  clinics      RhdClinic[]
}

/// Per-Saturday RHD clinic row (attending on duty, director on point,
/// procedures booked). One row per clinic date per term.
model RhdClinic {
  id               String        @id @default(cuid())
  termId           String
  /// Noon-UTC anchored calendar date; compare by UTC day key.
  clinicDate       DateTime
  attendingId      String?
  directorName     String?
  proceduresBooked Int?
  term             Term          @relation(fields: [termId], references: [id], onDelete: Restrict)
  attending        RhdAttending? @relation(fields: [attendingId], references: [id], onDelete: SetNull)

  @@unique([termId, clinicDate])
}

model RecruitmentCycle {
  id              String           @id @default(cuid())
  track           RecruitmentTrack
  termId          String
  title           String
  status          CycleStatus      @default(DRAFT)
  publicSlug      String           @unique
  opensAt         DateTime?
  closesAt        DateTime?
  departments     String[]
  acceptsRenewals     Boolean          @default(false)
  decisionsReleasedAt DateTime?
  isTermTraining  Boolean          @default(false)
  quizPassPercent Int              @default(80)
  quizMaxAttempts Int              @default(3)
  createdById     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  term         Term                @relation(fields: [termId], references: [id], onDelete: Restrict)
  createdBy    Person              @relation("RecruitmentCycleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  sections     FormSection[]
  fields       FormField[]
  applicants   Applicant[]
  applications Application[]
  trainings    Training[]
  cycleEmails  RecruitmentCycleEmail[]

  @@index([status, track])
}

model FormSection {
  id             String         @id @default(cuid())
  cycleId        String
  title          String
  description    String?
  order          Int
  departmentCode String?
  appliesTo      ApplicantScope @default(BOTH)
  purpose        FormPurpose    @default(APPLICATION)

  cycle  RecruitmentCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  fields FormField[]

  @@index([cycleId, order])
}

model FormField {
  id           String    @id @default(cuid())
  sectionId    String
  cycleId      String
  key          String
  label        String
  helpText     String?
  type         FieldType
  required     Boolean   @default(false)
  options      Json?
  validation   Json?
  correctValue String?
  order        Int

  section FormSection      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  cycle   RecruitmentCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, key])
  @@index([sectionId, order])
}

model Applicant {
  id         String   @id @default(cuid())
  cycleId    String
  applicantPersonId String?
  firstName  String
  lastName   String
  email      String
  /// Must equal lower(email); set by the submission service. Backs the (cycleId, emailLower) dedup unique.
  emailLower String
  netId      String?
  phone      String?
  createdAt  DateTime @default(now())

  cycle           RecruitmentCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  /// Set for signed-in renewals; null for anonymous new applicants. Links the
  /// submission to the verified HAVEN Hub account.
  applicantPerson Person?          @relation("ApplicantPerson", fields: [applicantPersonId], references: [id], onDelete: SetNull)
  applications    Application[]

  @@unique([cycleId, emailLower])
  @@unique([cycleId, applicantPersonId])
  @@index([applicantPersonId])
}

model Application {
  id                String            @id @default(cuid())
  cycleId           String
  applicantId       String
  answers           Json
  applicantType     ApplicantType     @default(NEW)
  departmentChoices String[]
  renewalDepartment String?
  // ordered subcommittee IDs the applicant ranked (1st -> Nth); hoisted from the
  // SUBCOMMITTEE_RANK field answer at submit, like departmentChoices.
  subcommitteeRanking      String[]
  assignedSubcommitteeId   String?
  assignedSubcommitteeById String?
  assignedSubcommitteeAt   DateTime?
  status            ApplicationStatus @default(SUBMITTED)
  submittedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  cycle       RecruitmentCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  applicant   Applicant        @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  acceptances Acceptance[]
  interviews  Interview[]
  assignedSubcommittee   Subcommittee? @relation("applicationAssignedSubcommittee", fields: [assignedSubcommitteeId], references: [id], onDelete: SetNull)
  assignedSubcommitteeBy Person?       @relation("applicationSubcommitteeAssigner", fields: [assignedSubcommitteeById], references: [id], onDelete: SetNull)

  @@unique([cycleId, applicantId])
  @@index([cycleId, submittedAt])
}

model Acceptance {
  id             String    @id @default(cuid())
  applicationId  String
  departmentCode String
  approvedById   String
  notes          String?
  emailedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  application Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  approvedBy  Person              @relation("recruitmentAcceptanceApprover", fields: [approvedById], references: [id], onDelete: Restrict)
  contract    OnboardingContract?

  @@unique([applicationId, departmentCode])
  @@index([applicationId])
}

model OnboardingContract {
  id                       String         @id @default(cuid())
  acceptanceId             String         @unique
  token                    String         @unique
  status                   ContractStatus @default(PENDING)
  firstName                String
  lastName                 String
  email                    String
  netId                    String?
  phone                    String?
  dateOfBirth              DateTime?
  dietaryRestrictions      String?
  yaleAffiliation          String?
  gradYear                 String?
  agreementSignature       String?
  professionalismSignature String?
  trainingSignature        String?
  initials                 String?
  epicNeeded               Boolean        @default(false)
  hasEpic                  Boolean        @default(false)
  existingEpicId           String?
  epicAccessType           String?
  worksWithYnhh            Boolean        @default(false)
  hipaaStoredName          String?
  hipaaFileName            String?
  hipaaMimeType            String?
  hipaaSize                Int?
  hipaaCompletedAt         DateTime?
  sentAt                   DateTime?
  submittedAt              DateTime?
  promotedAt               DateTime?
  promotedById             String?
  promotedPersonId         String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  acceptance     Acceptance @relation(fields: [acceptanceId], references: [id], onDelete: Cascade)
  promotedBy     Person?    @relation("contractPromotedBy", fields: [promotedById], references: [id], onDelete: SetNull)
  promotedPerson Person?    @relation("contractPromotedPerson", fields: [promotedPersonId], references: [id], onDelete: SetNull)

  @@index([status])
}

model Training {
  id                          String          @id @default(cuid())
  personId                    String
  termId                      String
  cycleId                     String
  track                       TrainingTrack   @default(VOLUNTEER)
  status                      TrainingStatus  @default(PENDING)
  completedVia                TrainingMethod?
  completedAt                 DateTime?
  attendanceRecordedById      String?
  attendanceRecordedAt        DateTime?
  locked                      Boolean         @default(false)
  lockResetAt                 DateTime?
  additionalShiftAvailability String?
  minShiftsWanted             String?
  feedback                    String?
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt

  person               Person           @relation("trainingPerson", fields: [personId], references: [id], onDelete: Cascade)
  term                 Term             @relation(fields: [termId], references: [id], onDelete: Cascade)
  cycle                RecruitmentCycle @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  attendanceRecordedBy Person?          @relation("trainingAttendanceRecorder", fields: [attendanceRecordedById], references: [id], onDelete: SetNull)
  attempts             QuizAttempt[]

  @@unique([personId, termId, track])
  @@index([termId])
}

model QuizAttempt {
  id         String   @id @default(cuid())
  trainingId String
  answers    Json
  score      Int
  total      Int
  passed     Boolean
  takenAt    DateTime @default(now())

  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@index([trainingId, takenAt])
}

model Interview {
  id             String            @id @default(cuid())
  applicationId  String
  departmentCode String
  scheduledAt    DateTime?
  zoomLink       String?
  invitedAt      DateTime?
  decision       InterviewDecision @default(PENDING)
  decidedById    String?
  decidedAt      DateTime?
  notes          String?
  createdById    String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  application Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  decidedBy   Person?             @relation("interviewDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  createdBy   Person              @relation("interviewCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  panelists   InterviewPanelist[]
  evaluations Evaluation[]

  @@unique([applicationId, departmentCode])
  @@index([applicationId])
}

model InterviewPanelist {
  id          String  @id @default(cuid())
  interviewId String
  personId    String
  isLead      Boolean @default(false)

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  person    Person    @relation("interviewPanelistPerson", fields: [personId], references: [id], onDelete: Cascade)

  @@unique([interviewId, personId])
  @@index([personId])
}

model Evaluation {
  id             String         @id @default(cuid())
  interviewId    String
  evaluatorId    String
  recommendation Recommendation
  comments       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  evaluator Person    @relation("interviewEvaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)

  @@unique([interviewId, evaluatorId])
}

/// Admin-configurable settings stored as key/value overrides. The key is a
/// well-known string defined in the code registry; value is stored as JSON to
/// support any scalar or structured type. updatedById is a loose reference to
/// the Person who last changed the setting (no FK, so settings survive person
/// deletion).
model Setting {
  key         String   @id
  value       Json
  updatedById String?
  updatedAt   DateTime @updatedAt
}

enum CourseProgressStatus {
  IN_PROGRESS
  COMPLETE
}

model Course {
  id              String             @id @default(cuid())
  title           String
  description     String?
  isActive        Boolean            @default(true)
  /// When true, the course is assigned to every department (org-wide).
  assignToAll     Boolean            @default(false)
  /// Who the course targets, composed with department / assignToAll scoping.
  audience        CourseAudience     @default(EVERYONE)
  /// Ordering in the catalog / management list.
  position        Int                @default(0)
  /// Launch file from imsmanifest.xml (e.g. "index.html"). Null = no package uploaded yet (draft).
  scormEntryHref  String?
  /// SCORM version string, e.g. "1.2".
  scormVersion    String?
  /// When the current package was ingested.
  scormUploadedAt DateTime?
  /// Ordered SCO list from imsmanifest.xml: [{ id, title, href }]. Null = legacy single-SCO package.
  scormScos       Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  departments     CourseDepartment[]
  progress        CourseProgress[]
  scoProgress     ScoProgress[]
}

enum CourseAudience {
  EVERYONE
  DIRECTORS
  VOLUNTEERS
}

model CourseDepartment {
  id           String     @id @default(cuid())
  courseId     String
  departmentId String
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([courseId, departmentId])
  @@index([departmentId])
}

model CourseProgress {
  id             String               @id @default(cuid())
  personId       String
  courseId       String
  status         CourseProgressStatus @default(IN_PROGRESS)
  completedAt    DateTime?
  /// Raw cmi.core.lesson_status reported by the package.
  lessonStatus   String?
  /// cmi.core.score.raw when reported; null otherwise.
  scoreRaw       Int?
  /// cmi.suspend_data -- can be large.
  suspendData    String?              @db.Text
  /// cmi.core.lesson_location for resume.
  lessonLocation String?
  person         Person               @relation(fields: [personId], references: [id], onDelete: Cascade)
  course         Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([personId, courseId])
  @@index([courseId])
}

model ScoProgress {
  id             String    @id @default(cuid())
  personId       String
  courseId       String
  /// Manifest <item> identifier (matches Course.scormScos[].id).
  scoId          String
  completedAt    DateTime?
  /// Raw cmi.core.lesson_status reported by this SCO.
  lessonStatus   String?
  /// cmi.core.score.raw when reported; null otherwise.
  scoreRaw       Int?
  /// cmi.suspend_data for this SCO -- can be large.
  suspendData    String?   @db.Text
  /// cmi.core.lesson_location for resume.
  lessonLocation String?
  person         Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  course         Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([personId, courseId, scoId])
  @@index([courseId])
}

/// Single-use, hashed, expiring magic-link token for the applicant portal.
/// Only the SHA-256 hash of the token is stored; the raw token lives only in
/// the emailed link.
model ApplicantPortalToken {
  id         String    @id @default(cuid())
  emailLower String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([emailLower])
}
