{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma migrate deploy && next build",
  "crons": [
    { "path": "/api/cron/drain", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/nightly", "schedule": "0 6 * * *" },
    { "path": "/api/cron/reminders", "schedule": "0 13 * * *" }
  ]
}
