# --- Database ---------------------------------------------------------------
# Local dev points at the compose postgres (host port 5434 — 5433 is often taken by other local stacks).
DATABASE_URL=postgresql://haven:haven_dev@localhost:5434/havenhub
# Used by `npm test` (vitest.setup.ts). Created by `npm run test:prepare`.
TEST_DATABASE_URL=postgresql://haven:haven_dev@localhost:5434/havenhub_test

# --- Auth -------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me
# Microsoft Entra ID app registration (Yale tenant).
# OPTIONAL in development (dev credentials login works without them),
# REQUIRED in production — boot fails loudly if missing.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
